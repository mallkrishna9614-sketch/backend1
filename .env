# ─── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/lpu-canteen?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_key_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ─── Razorpay Test Mode ────────────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys → Test Mode
# Test keys start with: rzp_test_
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
